<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="Sauce Demo 26"
       parallel="tests">

    <listeners>
        <listener class-name="utilits.TestListener"/>
        <listener class-name="retrysingletest.AnnotationTransformer"/>
</listeners>
    <test name="Thread 1">
        <classes>
            <class name="tests.LoginTest">
                <methods>
                    <include name="checkPositiveCred"/>
                </methods>
            </class>

        </classes>
    </test>

    <test name="Thread 2">
        <classes>
            <class name="tests.LocatorTest"/>
            <class name="tests.CartTest"/>
        </classes>
    </test>
</suite>
